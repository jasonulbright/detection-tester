<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
      Margin="8">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="240"/>
    </Grid.RowDefinitions>

    <!-- ====================  TOOLBAR  ==================== -->
    <Border Grid.Row="0" Padding="8,6,8,8"
            Background="{DynamicResource MahApps.Brushes.Gray10}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Filter:"   VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox   Grid.Column="1" x:Name="txtFilter"
                       ToolTip="Substring match across DisplayName, Publisher, and DisplayVersion."/>

            <TextBlock Grid.Column="3" Text="Scope:"    VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox  Grid.Column="4" x:Name="cboScope" SelectedIndex="0">
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="Machine (HKLM)"/>
                <ComboBoxItem Content="User (HKCU)"/>
            </ComboBox>

            <Button Grid.Column="6" x:Name="btnRefresh"           Content="Refresh"           Style="{DynamicResource MahApps.Styles.Button.Square}"        Controls:ControlsHelper.ContentCharacterCasing="Normal" Padding="10,4" Margin="4,0" ToolTip="Re-enumerate ARP."/>
            <Button Grid.Column="7" x:Name="btnUseForDetection"   Content="Use for detection" Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" Controls:ControlsHelper.ContentCharacterCasing="Normal" Padding="10,4" Margin="4,0" Visibility="Collapsed" ToolTip="Switch to the Detection Tester module with this app's registry key prefilled."/>
            <Button Grid.Column="8" x:Name="btnCopyDetails"       Content="Copy details"      Style="{DynamicResource MahApps.Styles.Button.Square}"        Controls:ControlsHelper.ContentCharacterCasing="Normal" Padding="10,4" Margin="4,0" Visibility="Collapsed" ToolTip="Copy all fields of the selected app to the clipboard."/>
        </Grid>
    </Border>

    <!-- ====================  GRID  ==================== -->
    <DataGrid Grid.Row="1" x:Name="dgApps"
              Margin="0,8,0,0"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              IsReadOnly="True"
              SelectionMode="Single"
              SelectionUnit="FullRow"
              HeadersVisibility="Column"
              GridLinesVisibility="Horizontal"
              RowHeaderWidth="0"
              BorderThickness="0"
              ColumnHeaderHeight="30">
        <DataGrid.Columns>
            <DataGridTextColumn Header="DisplayName"    Binding="{Binding DisplayName}"    Width="*"/>
            <DataGridTextColumn Header="Publisher"      Binding="{Binding Publisher}"      Width="200"/>
            <DataGridTextColumn Header="DisplayVersion" Binding="{Binding DisplayVersion}" Width="140"/>
            <DataGridTextColumn Header="Architecture"   Binding="{Binding Architecture}"   Width="90"/>
            <DataGridTextColumn Header="Scope"          Binding="{Binding Scope}"          Width="90"/>
        </DataGrid.Columns>
    </DataGrid>

    <!-- ====================  DIVIDER  ==================== -->
    <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                  Background="{DynamicResource MahApps.Brushes.Gray8}"
                  ResizeDirection="Rows"/>

    <!-- ====================  DETAIL PANEL  ==================== -->
    <Border Grid.Row="3" Padding="12" Margin="0,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid x:Name="detailPanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="DisplayName:"          FontWeight="SemiBold" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="dtlDisplayName"      FontFamily="Cascadia Code, Consolas, Courier New" Margin="0,2"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Publisher:"            FontWeight="SemiBold" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="dtlPublisher"        FontFamily="Cascadia Code, Consolas, Courier New" Margin="0,2"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="DisplayVersion:"       FontWeight="SemiBold" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="dtlDisplayVersion"   FontFamily="Cascadia Code, Consolas, Courier New" Margin="0,2"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Architecture / Scope:" FontWeight="SemiBold" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="dtlArchScope"        FontFamily="Cascadia Code, Consolas, Courier New" Margin="0,2"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="RegistryKey:"          FontWeight="SemiBold" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="dtlRegistryKey"      FontFamily="Cascadia Code, Consolas, Courier New" Margin="0,2" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="UninstallString:"      FontWeight="SemiBold" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="dtlUninstallString"  FontFamily="Cascadia Code, Consolas, Courier New" Margin="0,2" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="QuietUninstallString:" FontWeight="SemiBold" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="dtlQuietUninstall"   FontFamily="Cascadia Code, Consolas, Courier New" Margin="0,2" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="7" Grid.Column="0" Text="InstallLocation:"      FontWeight="SemiBold" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="7" Grid.Column="1" x:Name="dtlInstallLocation"  FontFamily="Cascadia Code, Consolas, Courier New" Margin="0,2" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="8" Grid.Column="0" Text="InstallDate:"          FontWeight="SemiBold" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="8" Grid.Column="1" x:Name="dtlInstallDate"      FontFamily="Cascadia Code, Consolas, Courier New" Margin="0,2"/>
            </Grid>
        </ScrollViewer>
    </Border>
</Grid>
